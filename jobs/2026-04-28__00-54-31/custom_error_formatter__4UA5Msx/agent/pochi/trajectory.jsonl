{"type":"message-part","messageId":"c0decaeb-cb16-4317-9139-bc632d9f6251","role":"assistant","index":3,"part":{"type":"tool-readFile","toolCallId":"aCZtTELZm7XB5e5y","state":"output-available","input":{"path":"/home/user/app/server.ts"},"output":{"content":"import * as trpcExpress from '@trpc/server/adapters/express';\nimport express from 'express';\nimport { initTRPC } from '@trpc/server';\nimport { z, ZodError } from 'zod';\n\nexport const t = initTRPC.create();\n\nconst appRouter = t.router({\n  addPost: t.procedure\n    .input(z.object({ title: z.string().min(5) }))\n    .mutation(({ input }) => {\n      return { id: 1, title: input.title };\n    }),\n});\n\nconst app = express();\n\napp.use(\n  express.json(),\n  '/trpc',\n  trpcExpress.createExpressMiddleware({\n    router: appRouter,\n    createContext: () => ({}),\n  }),\n);\n\napp.listen(3000, () => {\n  console.log('Server listening on port 3000');\n});\n","isTruncated":false},"callProviderMetadata":{"vertex":{"thoughtSignature":""}}}}
